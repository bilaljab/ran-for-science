# Postgres connection string
DATABASE_URL="postgresql://user:password@localhost:5432/ran_for_science?schema=public"

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Seed script (REQUIRED — no default credentials are created; pick your own strong password, 12+ chars)
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# Cloudflare R2 (optional in dev — falls back to local disk storage when unset)
R2_BUCKET=""
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# Email delivery (password reset / verification links)
# REQUIRED in production — the server refuses to start without it.
# In dev, leaving this unset prints links to the console instead of emailing them.
RESEND_API_KEY=""
EMAIL_FROM="RAN For Science <no-reply@ranforscience.com>"

# Base URL used to build links inside emails (password reset, verification)
NEXTAUTH_URL="http://localhost:3000"

# Cloudflare Turnstile (bot/spam protection on the public contact/quote/apply
# forms). Optional in dev — without it, CAPTCHA verification is skipped with
# a console warning. Configure both before relying on it in production; the
# site key is meant to be public (it's embedded in the page), the secret key
# is not. Get both from https://dash.cloudflare.com/ -> Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
